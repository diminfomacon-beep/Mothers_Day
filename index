<script>
// IMAGE D// 1. DATA CONFIGURATION
// Replace these URLs with your actual GitHub raw links
const productData = {
  'Tumbler': {
    price: 15,
    variants: {
      'pink': ["https://raw.githubusercontent.com/user/repo/main/p1.jpg", "https://raw.githubusercontent.com/user/repo/main/p2.jpg"],
      'blue': ["https://raw.githubusercontent.com/user/repo/main/b1.jpg", "https://raw.githubusercontent.com/user/repo/main/b2.jpg"]
    }
  },
  'Keychain': {
    price: 5,
    variants: {
      'gold': ["https://raw.githubusercontent.com/user/repo/main/g1.jpg"],
      'silver': ["https://raw.githubusercontent.com/user/repo/main/s1.jpg"]
    }
  }
};

// State tracking
let currentSelections = {}; // Tracks { productName: { variant: 'pink', index: 0 } }
let selected = [];

// Initialize state for all products
function init() {
  for (let key in productData) {
    currentSelections[key] = {
      variant: Object.keys(productData[key].variants)[0],
      index: 0
    };
  }
}
init();

// 2. UI CONTROLS
function changeVariant(productName, variantName) {
  currentSelections[productName].variant = variantName;
  currentSelections[productName].index = 0; // Reset gallery to first image of new variant
  updateUI(productName);
}

function changeImage(productName, direction) {
  const p = currentSelections[productName];
  const images = productData[productName].variants[p.variant];
  
  p.index = (p.index + direction + images.length) % images.length;
  updateUI(productName);
}

function updateUI(productName) {
  const p = currentSelections[productName];
  const imgElement = document.getElementById(`img-${productName}`);
  if (imgElement) {
    imgElement.src = productData[productName].variants[p.variant][p.index];
  }
}

// 3. BUNDLE LOGIC
function addItem(name) {
  const state = currentSelections[name];
  const data = productData[name];
  const img = data.variants[state.variant][state.index];

  let existing = selected.find(i => i.name === name && i.variant === state.variant);

  if (existing) {
    existing.qty++;
  } else {
    selected.push({ name, variant: state.variant, price: data.price, img, qty: 1 });
  }
  render();
}

// ... Keep your render(), changeQty(), and updateTotal() functions from your original code ...ATA

function render() {
  let container = document.getElementById("selectedItems");
  container.innerHTML = "";

  selected.forEach((item, index) => {
    container.innerHTML += `
      <div class="selected-item">
        <img src="${item.img}">
        <small>${item.name} (${item.variant})</small>

        <div class="qty-controls">
          <button onclick="changeQty(${index},-1)">-</button>
          <span>${item.qty}</span>
          <button onclick="changeQty(${index},1)">+</button>
        </div>

        <button onclick="removeItem(${index})">Remove</button>
      </div>
    `;
  });

  updateTotal();
}

function changeQty(i, change) {
  selected[i].qty += change;
  if (selected[i].qty <= 0) selected.splice(i,1);
  render();
}

function removeItem(i) {
  selected.splice(i,1);
  render();
}

function clearBundle() {
  selected = [];
  render();
}

function updateTotal() {
  let total = selected.reduce((sum,i)=>sum + i.price*i.qty,0);
  let count = selected.reduce((sum,i)=>sum + i.qty,0);

  let discount = 0;
  if (count >= 3) discount = total * 0.10;
  if (count >= 5) discount = total * 0.20;

  let final = total - discount;

  document.getElementById("items").innerText = "Items: " + count;
  document.getElementById("discount").innerText = "Discount: $" + discount.toFixed(2);
  document.getElementById("total").innerText = "$" + final.toFixed(2);
  document.getElementById("paypal-amount").value = final.toFixed(2);
  document.getElementById("savings").innerText =
    discount > 0 ? "🎉 You saved $" + discount.toFixed(2) : "";
}
</script>

